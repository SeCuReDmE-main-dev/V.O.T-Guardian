# Minimal fast template: Python 3.10.11 + Torch CPU 2.1.0 + NumPy 1.26.4 + Librosa 0.10.1
# Excludes MindsDB server to keep image small and builds fast. Use this to accelerate sandbox starts.
FROM python:3.10.11-slim-bullseye

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_ROOT_USER_ACTION=ignore

USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
    libsndfile1 \
    ffmpeg \
    build-essential \
    gcc \
    g++ \
    git \
    curl \
    libffi-dev \
    python3-dev \
    pkg-config \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/vot-guardian

# Lean core requirements file (only librosa)
COPY e2b-template/sandbox-core-requirements.v2.txt /opt/vot-guardian/sandbox-core-requirements.txt

# Harden pip/setuptools/wheel on slim; install Torch CPU and NumPy pins
RUN python -m ensurepip --upgrade || true && \
    python -m pip install --no-cache-dir --ignore-installed "pip<25" "setuptools>=68" "wheel>=0.41" && \
    python -m pip install --no-cache-dir torch==2.1.0 --index-url https://download.pytorch.org/whl/cpu && \
    python -m pip install --no-cache-dir numpy==1.26.4

# Install librosa and friends
RUN echo "----- BEGIN sandbox-core-requirements.txt -----" && \
    cat /opt/vot-guardian/sandbox-core-requirements.txt && \
    echo "\n----- END sandbox-core-requirements.txt -----" && \
    python -m pip install --no-cache-dir -r /opt/vot-guardian/sandbox-core-requirements.txt

# Install MindsDB client and Whisper; create a lightweight alias so `import mindsdb`
# succeeds in sandboxes without the full server package.
RUN pip install --no-cache-dir \
    mindsdb_sdk \
    openai-whisper \
    && python - <<'PY'
import importlib
import pathlib

sdk = importlib.import_module('mindsdb_sdk')
site_packages = pathlib.Path(sdk.__file__).resolve().parent.parent
alias_pkg = site_packages / 'mindsdb'
alias_pkg.mkdir(exist_ok=True)
alias_init = alias_pkg / '__init__.py'
alias_init.write_text(
    "import mindsdb_sdk as _sdk\n"
    "from mindsdb_sdk import *  # noqa: F401,F403\n"
    "__all__ = [name for name in globals() if not name.startswith('_')]\n"
    "__version__ = getattr(_sdk, '__version__', '0.0.0')\n"
)
PY

# Non-root user for runtime, if applicable
USER user
