FROM python:3.10.11-slim-bullseye AS builder

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential gcc g++ git curl libffi-dev python3-dev pkg-config ca-certificates \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/vot-guardian

RUN python -m ensurepip --upgrade || true \
    && python -m pip install --no-cache-dir --ignore-installed "pip<25" "setuptools>=68" "wheel>=0.41" \
    && python -m pip install --no-cache-dir torch==2.1.0 --index-url https://download.pytorch.org/whl/cpu \
    && python -m pip install --no-cache-dir numpy==1.26.4 librosa==0.10.1

# Install MindsDB client and Whisper; create a lightweight alias so `import mindsdb`
# works even when only the SDK is installed.
RUN pip install --no-cache-dir \
    mindsdb_sdk \
    openai-whisper \
    && python -c 'exec("""import importlib
import pathlib
from importlib import metadata as md

sdk = importlib.import_module("mindsdb_sdk")
site_packages = pathlib.Path(sdk.__file__).resolve().parent.parent
alias_pkg = site_packages / "mindsdb"
alias_pkg.mkdir(exist_ok=True)
alias_init = alias_pkg / "__init__.py"
try:
    version = sdk.__version__
except AttributeError:
    try:
        version = md.version("mindsdb_sdk")
    except Exception:
        version = "0.0.0"
alias_init.write_text(f"import mindsdb_sdk as _sdk\\nfrom mindsdb_sdk import *  # noqa: F401,F403\\n__all__ = [name for name in globals() if not name.startswith(\"_\")]\\n__version__ = \"{version}\"\\n")
""")'

#
# Create non-root user (E2B best practice)
#
RUN id -u user >/dev/null 2>&1 || useradd -m -u 1000 user
USER user
WORKDIR /home/user
