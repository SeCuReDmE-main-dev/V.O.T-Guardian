# Ultra-minimal template to stay under 1h build: Python 3.10.11 + Torch CPU 2.1.0 + NumPy 1.26.4
FROM python:3.10.11-slim-bullseye

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_ROOT_USER_ACTION=ignore

USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    g++ \
    git \
    curl \
    libffi-dev \
    python3-dev \
    pkg-config \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/vot-guardian

# Harden pip/setuptools/wheel; install Torch CPU and NumPy pins
RUN python -m ensurepip --upgrade || true && \
    python -m pip install --no-cache-dir --ignore-installed "pip<25" "setuptools>=68" "wheel>=0.41" && \
    python -m pip install --no-cache-dir torch==2.1.0 --index-url https://download.pytorch.org/whl/cpu && \
    python -m pip install --no-cache-dir numpy==1.26.4

# Install MindsDB client and Whisper; create a lightweight alias for `import mindsdb`
RUN pip install --no-cache-dir \
    mindsdb_sdk \
    openai-whisper \
    && python -c "exec(\"\"\"import importlib\nimport pathlib\nfrom importlib import metadata as md\nsdk = importlib.import_module('mindsdb_sdk')\nsite_packages = pathlib.Path(sdk.__file__).resolve().parent.parent\nalias_pkg = site_packages / 'mindsdb'\nalias_pkg.mkdir(exist_ok=True)\nalias_init = alias_pkg / '__init__.py'\ntry:\n    version = sdk.__version__\nexcept AttributeError:\n    try:\n        version = md.version('mindsdb_sdk')\n    except Exception:\n        version = '0.0.0'\nalias_init.write_text(f\"import mindsdb_sdk as _sdk\\\\nfrom mindsdb_sdk import *  # noqa: F401,F403\\\\n__all__ = [name for name in globals() if not name.startswith('_')]\\\\n__version__ = '{version}'\\\\n\")\n\"\"\")"

USER user
