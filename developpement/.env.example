# ==============================================
# V.O.T. GUARDIAN - ENVIRONMENT CONFIGURATION (Example)
# ==============================================
# Copy this file to .env and fill in your values locally.
# Do NOT commit your real .env to version control.

# ----------------------------------------------
# API KEYS & TOKENS (USER-PROVIDED)
# ----------------------------------------------
# E2B API Key for sandbox isolation
E2B_API_KEY=

# Optional: E2B custom template ID for pre-baked sandbox image
# Example: tpl_abc123def456
E2B_TEMPLATE_ID=

# Datadog API Key for monitoring and observability
DD_API_KEY=

# Optional: Red Hat API Key (for OpenShift, not required for dev)
REDHAT_API_KEY=

# ----------------------------------------------
# DATABASE CONNECTIONS
# ----------------------------------------------
# PostgreSQL Database
POSTGRESQL_URL=postgresql://vot_user:vot_password@localhost:5432/vot_guardian

# RethinkDB Database
RETHINKDB_HOST=localhost
RETHINKDB_PORT=28015
RETHINKDB_DB=vot_guardian
RETHINKDB_USER=vot_user
RETHINKDB_PASSWORD=vot_password

# MindsDB Database (running in Docker by default)
MINDSDB_URL=http://localhost:47334
MINDSDB_API_KEY=

# Optional: Provider keys for integrations (leave blank if not used)
GOOGLE_AI_API_KEY=

# ----------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------
# Flask settings
FLASK_APP=src.api.main:app
FLASK_ENV=development
FLASK_DEBUG=true

# API server config
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET_KEY=change_me_for_local_dev

# Audio Processing
MAX_AUDIO_FILE_SIZE=10485760
SUPPORTED_AUDIO_FORMATS=mp3,wav,ogg,opus
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SIZE=500

# ----------------------------------------------
# SECURITY & PROTOCOLE TENEBRIS
# ----------------------------------------------
TENEBRIS_MASTER_KEY=
TENEBRIS_AES_KEY=

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# SSL/TLS (optional for dev)
SSL_CERT_PATH=
SSL_KEY_PATH=
TLS_VERSION=TLSv1.3

# ----------------------------------------------
# MONITORING & OBSERVABILITY
# ----------------------------------------------
DD_ENV=development
DD_SERVICE=vot-guardian
DD_VERSION=1.0.0
DD_AGENT_HOST=localhost

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=

METRICS_ENABLED=true
METRICS_PORT=9090

# ----------------------------------------------
# PERFORMANCE SETTINGS
# ----------------------------------------------
E2B_POOL_MIN_SIZE=5
E2B_POOL_MAX_SIZE=50
E2B_SANDBOX_TIMEOUT=30

ML_MODEL_PATH=/models/vot-cnn-lstm-v2.1.pth
ML_INFERENCE_TIMEOUT=5
ML_BATCH_SIZE=32

# GPU (optional)
CUDA_VISIBLE_DEVICES=0
GPU_MEMORY_FRACTION=0.8

# ----------------------------------------------
# COMPLIANCE & AUDIT
# ----------------------------------------------
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=
AUDIT_RETENTION_DAYS=2555

COMPLIANCE_LOI25_ENABLED=true
COMPLIANCE_GDPR_ENABLED=true
COMPLIANCE_PIPEDA_ENABLED=true

# ----------------------------------------------
# DEVELOPMENT SETTINGS
# ----------------------------------------------
DEBUG_MODE=true
HOT_RELOAD=true

TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/vot_test
MOCK_E2B_IN_TESTS=false
